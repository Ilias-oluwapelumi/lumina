PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=lumina_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=lumina_refresh_secret_change_this_in_production_2024
JWT_REFRESH_EXPIRES_IN=30d

# Database (SQLite for simplicity, swap to Postgres in production)
DB_PATH=./lumina.db

# App
APP_NAME=Lumina
FRONTEND_URL=http://localhost:3000

# VTU Provider (stub — replace with real keys)
VTU_API_URL=https://api.vtugenie.ng/v1
VTU_API_KEY=your_vtu_api_key_here
VTU_SECRET=your_vtu_secret_here

# Paystack (for card funding)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key_here
